<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.petschool.mapper.PackageItemMapper">
    <select id="selectByPackageId" resultType="com.petschool.entity.PackageItem">
        SELECT id, package_id, name, included, extra_price FROM package_item WHERE package_id = #{packageId}
    </select>
</mapper>
